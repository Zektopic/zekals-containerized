# ALS Communication System Environment Variables
# Copy this file to .env and configure your settings

# Hardware acceleration mode for MediaPipe
# Options: CPU, GPU
HARDWARE_MODE=CPU

# Gemini AI API Key (required for AI suggestions)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# User location for weather and local information
# Example: "New York, NY" or "London, UK"
LOCATION=Your City, Country

# Display server for X11 forwarding (usually :0 on Linux)
DISPLAY=:0